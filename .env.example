# Server Configuration
AUTH_SERVER_PORT=8080
AUTH_SERVER_READ_TIMEOUT=10s
AUTH_SERVER_WRITE_TIMEOUT=10s
AUTH_SERVER_IDLE_TIMEOUT=60s

# Database Configuration
AUTH_DATABASE_HOST=localhost
AUTH_DATABASE_PORT=5432
AUTH_DATABASE_USER=postgres
AUTH_DATABASE_PASSWORD=postgres
AUTH_DATABASE_DBNAME=auth_service
AUTH_DATABASE_SSLMODE=disable
AUTH_DATABASE_MAX_OPEN_CONNS=25
AUTH_DATABASE_MAX_IDLE_CONNS=10
AUTH_DATABASE_CONN_MAX_LIFETIME=5m

# Redis Configuration
AUTH_REDIS_HOST=localhost
AUTH_REDIS_PORT=6379
AUTH_REDIS_PASSWORD=
AUTH_REDIS_DB=0

# JWT Configuration
AUTH_JWT_ACCESS_SECRET=change-this-to-a-secure-random-string
AUTH_JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
AUTH_JWT_ACCESS_DURATION=15m
AUTH_JWT_REFRESH_DURATION=168h
AUTH_JWT_ISSUER=auth-service

# Application Configuration
AUTH_APP_NAME=auth-service
AUTH_APP_ENVIRONMENT=development
AUTH_APP_LOG_LEVEL=debug
AUTH_APP_BCRYPT_COST=12
AUTH_APP_RATE_LIMIT_REQUESTS_PER_MINUTE=60
AUTH_APP_RATE_LIMIT_BURST_SIZE=20